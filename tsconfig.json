{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",

    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,

    "removeComments": false,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true,

    "types": ["node"]
  },
  "include": ["src"]
}